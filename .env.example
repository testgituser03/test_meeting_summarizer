# Copy to .env and fill in your token (do not commit .env)
# You can create a token at: Hugging Face → Settings → Access Tokens

# Preferred by huggingface_hub
HF_TOKEN=hf_your_token_here

# Back-compat (this repo)
HUGGING_FACE_TOKEN=hf_your_token_here

# Optional: allow MPS ops to fall back to CPU
PYTORCH_ENABLE_MPS_FALLBACK=1

